# --- Contact form email (Resend) ---
# 1. Create a free account at https://resend.com
# 2. Create an API key and paste it here.
# 3. Copy this file to `.env.local` (which stays out of git) and fill it in.
#    On your host (e.g. AWS Amplify / Vercel), add the same variables in the
#    project's Environment Variables settings.
RESEND_API_KEY=

# Optional — where contact messages are delivered.
# Defaults to denizugur.dev@gmail.com if omitted.
CONTACT_TO_EMAIL=denizugur.dev@gmail.com

# Optional — the "from" address shown on the email.
# Until you verify your own domain in Resend, leave this as the shared
# onboarding sender below. Once your domain is verified, use something like:
#   CONTACT_FROM_EMAIL=Portfolio Contact <hello@deniz-ugur.dev>
CONTACT_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>
